#!/usr/bin/env bash
#
# warp-taper — record evidence of Warp behavior for PR comments.
#
# Subcommands:
#   build      cargo build -p warp-oss in WARP_SOURCE
#   deploy     launch the built binary with the scenario's setup
#   record     screen capture + log tail during the scenario
#   evaluate   run the scenario's assertions
#   run        all four stages, end to end (the normal entry point)
#   bundle     re-emit the README + metadata for an existing tape
#
# A scenario is a directory under scenarios/ with:
#   scenario.md     human-readable repro steps
#   metadata.yaml   title, ticket, expected behavior
#   setup.sh        fixture setup (runs before record)
#   assertions.sh   post-recording programmatic checks (runs in evaluate)
#
# Output bundles ("tapes") land in tapes/<scenario>/. They contain:
#   master.mov, patches/*.png, logs/, stages/, README.md, metadata.yaml.

set -euo pipefail

# Resolve the repo root from this script's location, regardless of cwd.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Default to ~/personal/warp; can be overridden by env or flag.
: "${WARP_SOURCE:=${HOME}/personal/warp}"

# Source the stage helpers from lib/.
# shellcheck source=../lib/build.sh
source "${REPO_ROOT}/lib/build.sh"
# shellcheck source=../lib/deploy.sh
source "${REPO_ROOT}/lib/deploy.sh"
# shellcheck source=../lib/record.sh
source "${REPO_ROOT}/lib/record.sh"
# shellcheck source=../lib/evaluate.sh
source "${REPO_ROOT}/lib/evaluate.sh"
# shellcheck source=../lib/bundle.sh
source "${REPO_ROOT}/lib/bundle.sh"

usage() {
    cat <<'EOF'
warp-taper — record Warp behavior into PR-ready evidence bundles.

Usage:
  warp-taper run <scenario-dir>      Full pipeline (build, deploy, record, evaluate, bundle).
  warp-taper build                   Just build warp-oss in WARP_SOURCE.
  warp-taper deploy <scenario-dir>   Just launch the binary with the scenario's setup.
  warp-taper record <scenario-dir>   Just record (assumes binary is already running).
  warp-taper evaluate <scenario-dir> Just run the assertions.
  warp-taper bundle <scenario-dir>   Re-emit README/metadata for an existing tape.

Environment:
  WARP_SOURCE      Path to your warp checkout. Default: ~/personal/warp.

Output:
  Tapes land in tapes/<scenario-name>/, ignored by git (see .gitignore).
EOF
}

require_scenario() {
    local scenario_dir="$1"
    if [[ -z "${scenario_dir}" ]]; then
        echo "error: scenario directory required" >&2
        usage >&2
        exit 2
    fi
    if [[ ! -d "${scenario_dir}" ]]; then
        echo "error: scenario directory does not exist: ${scenario_dir}" >&2
        exit 2
    fi
    if [[ ! -f "${scenario_dir}/metadata.yaml" ]]; then
        echo "error: ${scenario_dir} is missing metadata.yaml" >&2
        exit 2
    fi
}

scenario_slug() {
    local scenario_dir="$1"
    basename "$(cd "${scenario_dir}" && pwd)"
}

tape_dir_for() {
    local scenario_dir="$1"
    local slug
    slug="$(scenario_slug "${scenario_dir}")"
    echo "${REPO_ROOT}/tapes/${slug}"
}

cmd_run() {
    local scenario_dir="$1"
    require_scenario "${scenario_dir}"

    local tape
    tape="$(tape_dir_for "${scenario_dir}")"
    mkdir -p "${tape}/stages" "${tape}/patches" "${tape}/logs"

    echo "==> [1/4] build"
    build_warp_oss "${WARP_SOURCE}" "${tape}/stages/01-build.log"

    echo "==> [2/4] deploy"
    deploy_with_setup "${scenario_dir}" "${WARP_SOURCE}" "${tape}/stages/02-deploy.log"

    echo "==> [3/4] record"
    record_session "${scenario_dir}" "${tape}" "${tape}/stages/03-record.log"

    echo "==> [4/4] evaluate"
    if evaluate_assertions "${scenario_dir}" "${tape}" "${tape}/stages/04-evaluate.log"; then
        local eval_status="pass"
    else
        local eval_status="fail"
    fi

    echo "==> bundle"
    bundle_tape "${scenario_dir}" "${tape}" "${eval_status}"

    echo
    echo "tape ready: ${tape}"
    echo "evaluate:  ${eval_status}"
    if [[ "${eval_status}" == "fail" ]]; then
        return 1
    fi
}

main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 2
    fi

    local subcmd="$1"
    shift

    case "${subcmd}" in
        run)
            cmd_run "${1:-}"
            ;;
        build)
            build_warp_oss "${WARP_SOURCE}" "/dev/stdout"
            ;;
        deploy)
            require_scenario "${1:-}"
            deploy_with_setup "$1" "${WARP_SOURCE}" "/dev/stdout"
            ;;
        record)
            require_scenario "${1:-}"
            local tape
            tape="$(tape_dir_for "$1")"
            mkdir -p "${tape}/patches" "${tape}/logs"
            record_session "$1" "${tape}" "/dev/stdout"
            ;;
        evaluate)
            require_scenario "${1:-}"
            local tape
            tape="$(tape_dir_for "$1")"
            evaluate_assertions "$1" "${tape}" "/dev/stdout"
            ;;
        bundle)
            require_scenario "${1:-}"
            local tape
            tape="$(tape_dir_for "$1")"
            bundle_tape "$1" "${tape}" "rerun"
            ;;
        -h|--help|help)
            usage
            ;;
        *)
            echo "error: unknown subcommand: ${subcmd}" >&2
            usage >&2
            exit 2
            ;;
    esac
}

main "$@"
