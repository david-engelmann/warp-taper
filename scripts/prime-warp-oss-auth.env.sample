# Optional overrides for scripts/prime-warp-oss-auth.sh.
#
# Copy this file to `prime-warp-oss-auth.env` (gitignored) if you need to
# override any of the defaults. The defaults below work for a standard
# macOS Warp install paired with a locally-built warp-oss binary; most
# users will not need to change anything.
#
# Source the file before running the helper:
#     set -a && source scripts/prime-warp-oss-auth.env && set +a
#     bash scripts/prime-warp-oss-auth.sh
#
# NEVER commit a file containing real keychain values, tokens, or other
# secrets. The script reads the keychain entry directly; nothing
# user-specific needs to be set in this file.

# macOS keychain service the User entry is read from.
# Public Warp release uses dev.warp.Warp-Stable. Warp Preview / Internal
# builds use other service names; check `defaults read NSGlobalDomain`
# or the bundle Info.plist if you need to confirm yours.
SOURCE_SERVICE=dev.warp.Warp-Stable

# macOS keychain service the User entry is written to. This is the
# service name warp-oss (built locally from warpdotdev/warp) reads on
# startup, per `AppId::new("dev", "warp", "WarpOss")`.
DEST_SERVICE=dev.warp.WarpOss

# Account name for the keychain entry. PersistedUser is stored under
# the literal `User` key by warp's secure_storage layer; you should not
# need to change this.
ACCOUNT=User
